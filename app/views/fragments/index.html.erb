<div class="max-w-4xl">
  <%= render "fragments/index/header" %>
  <% if @loading %>
    <%= render "shared/skeleton_fragment" %>
  <% else %>
    <% if @fragments.any? %>
      <%= render "fragments/index/list",
        fragments: @fragments %>
    <% else %>
      <%= render "fragments/index/empty" %>
    <% end %>
  <% end %>
</div>
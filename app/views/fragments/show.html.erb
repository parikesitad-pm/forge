<div class="max-w-5xl mx-auto">
  <%= link_to fragments_path,
      class: "inline-flex items-center gap-2 text-zinc-500 hover:text-zinc-300 transition mb-6" do %>
    <%= lucide_icon "arrow-left", class: "w-4 h-4" %>
    Back
  <% end %>
  <!-- Seed -->
  <div class="theme-surface border theme-border rounded-2xl p-8 mb-8">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2 text-sm font-medium text-zinc-400">
        <%= lucide_icon "sprout", class: "w-4 h-4" %>
        Seed
      </div>
      <div class="text-xs text-zinc-500">
        <%= @fragment.created_at.strftime("%d %b %Y • %H:%M") %>
      </div>
    </div>
    <div class="text-3xl font-bold leading-relaxed">
      <%= @fragment.content %>
    </div>
  </div>
  <% pinned = @fragment.observations.where(pinned: true).order(created_at: :desc) %>
  <% if pinned.any? %>
    <!-- Sparks -->
    <div class="theme-surface border theme-border rounded-2xl p-6 mb-8">
      <div class="flex items-center gap-2 mb-4">
        <%= lucide_icon "sparkles", class: "w-4 h-4 text-amber-400" %>
        <h2 class="font-semibold">
          Sparks
        </h2>
      </div>
      <div class="space-y-4">
        <% pinned.each do |observation| %>
          <div class="border-l-2 border-amber-400 pl-4">
            <div class="text-xs uppercase tracking-wider text-zinc-500 mb-2">
              <%= observation.role == "ai" ? "OWL" : "YOU" %>
            </div>
            <div class="leading-relaxed">
              <%= simple_format(observation.content) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  <!-- Conversation -->
  <div class="theme-surface border theme-border rounded-2xl p-6">
    <div class="flex items-center gap-2 mb-8">
      <%= lucide_icon "messages-square", class: "w-4 h-4 text-zinc-400" %>
      <h2 class="font-semibold">
        "Let's do a bit of brainstorming."      </h2>
    </div>
    <% if @fragment.observations.any? %>
      <div class="space-y-2 mb-8">
        <% @fragment.observations.order(:created_at).each do |observation| %>
          <% if observation.role == "user" %>
            <div class="flex justify-end">
              <div class="max-w-3xl">
                <div class="text-xs uppercase tracking-wider text-zinc-500 text-right mb-2">
                  YOU
                </div>
                <div class="bg-zinc-800 border border-zinc-700 text-zinc-100 rounded-2xl px-5 py-4">
                  <div class="leading-relaxed">
                    <%= simple_format(observation.content) %>
                  </div>
                </div>
                <div class="flex justify-end mt-2">
                  <% if observation.pinned? %>
                    <div class="flex items-center gap-3">
                      <span class="text-xs text-amber-400">
                        ⭐ Spark
                      </span>
                      <%= button_to "Unpin",
                          unpin_fragment_observation_path(@fragment, observation),
                          method: :patch,
                          class: "text-xs text-zinc-500 hover:text-zinc-300 bg-transparent border-0 p-0 cursor-pointer" %>
                    </div>
                  <% else %>
                    <%= button_to "📌 Pin Spark",
                        pin_fragment_observation_path(@fragment, observation),
                        method: :patch,
                        class: "text-xs text-zinc-500 hover:text-amber-400 bg-transparent border-0 p-0 cursor-pointer" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% else %>
            <div class="flex justify-start">
              <div class="max-w-3xl">
                <div class="text-xs uppercase tracking-wider text-zinc-500 mb-2">
                  OWL
                </div>
                <div class="bg-zinc-900 border border-zinc-800 text-zinc-200 rounded-2xl px-5 py-4">
                  <div class="leading-relaxed">
                    <%= simple_format(observation.content) %>
                  </div>
                </div>
                <div class="flex justify-start mt-2">
                  <% if observation.pinned? %>
                    <div class="flex items-center gap-3">
                      <span class="text-xs text-amber-400">
                        ⭐ Spark
                      </span>
                      <%= button_to "Unpin",
                          unpin_fragment_observation_path(@fragment, observation),
                          method: :patch,
                          class: "text-xs text-zinc-500 hover:text-zinc-300 bg-transparent border-0 p-0 cursor-pointer" %>
                    </div>
                  <% else %>
                    <%= button_to "📌 Pin Spark",
                        pin_fragment_observation_path(@fragment, observation),
                        method: :patch,
                        class: "text-xs text-zinc-500 hover:text-amber-400 bg-transparent border-0 p-0 cursor-pointer" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
    <%= form_with model: [@fragment, Observation.new] do |form| %>
      <div class="mb-4">
        <%= form.text_area :content,
            rows: 5,
            placeholder: "Continue thinking...",
            class: "w-full rounded-2xl border theme-border bg-transparent p-4 focus:outline-none focus:ring-2 focus:ring-zinc-500 resize-none" %>
      </div>
      <div class="flex justify-end">
        <%= form.submit "Continue Thinking",
            class: "px-5 py-3 rounded-xl bg-zinc-100 hover:bg-white text-zinc-900 font-medium transition cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
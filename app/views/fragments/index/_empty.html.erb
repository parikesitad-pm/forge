<div
  class="
    theme-surface
    border
    theme-border
    rounded-2xl
    p-16
    text-center
  "
>
  <%= lucide_icon "sprout",
      class:"
        w-12
        h-12
        mx-auto
        mb-5
        text-pink-500
      " %>
  <h2
    class="
      text-xl
      font-semibold
    "
  >
    No Fragments Yet
  </h2>
  <p
    class="
      mt-3
      text-zinc-500
    "
  >
    Plant your first thought and let Forge help it grow.
  </p>
  <%= link_to "Create Fragment",
      new_fragment_path,
      class:"
        inline-flex
        mt-8
        px-5
        py-3
        rounded-xl
        bg-pink-500
        hover:bg-pink-600
        transition
      " %>
</div>
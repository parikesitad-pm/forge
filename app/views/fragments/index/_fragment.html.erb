<%= link_to fragment_path(fragment), class: "block group" do %>
  <div
  class="border theme-border rounded-2xl p-5 theme-surface transition hover:border-pink-500 hover:-translate-y-0.5"
>
    <div class="text-lg font-medium leading-relaxed line-clamp-3">
      <%= fragment.content %>
    </div>
    <div class="flex items-center justify-between mt-5">
      <span class="text-xs text-zinc-500">
        <%= fragment.created_at.strftime("%d %b %Y • %H:%M") %>
      </span>
      <span
      class="text-xs text-pink-400 opacity-0 group-hover:opacity-100 transition"
    >
        Open →
      </span>
    </div>
  </div>
<% end %>

<div class="space-y-4">
  <% 6.times do %>
    <div
      class="
        animate-pulse
        rounded-2xl
        border
        theme-border
        p-5
      "
    >
      <div
        class="
          h-6
          rounded
          bg-zinc-700
          w-3/4
          mb-4
        "
      ></div>
      <div
        class="
          h-4
          rounded
          bg-zinc-800
          w-full
          mb-2
        "
      ></div>
      <div
        class="
          h-4
          rounded
          bg-zinc-800
          w-5/6
        "
      ></div>
    </div>
  <% end %>
</div>
<div
  class="
    opacity-0
    group-hover:opacity-100
    transition-all
    duration-200
    flex
    items-center
    gap-1
    mb-2

    <%= observation.role == 'user' ? 'justify-end' : 'justify-start' %>
  "
>
  <% if observation.pinned? %>
    <%= button_to unpin_fragment_observation_path(fragment, observation),
        method: :patch,
        class: "
          w-8
          h-8
          rounded-lg
          hover:bg-zinc-800
          transition
          flex
          items-center
          justify-center
          text-amber-400
        " do %>
      <%= lucide_icon "star",
          class: "w-4 h-4 fill-current" %>
    <% end %>
  <% else %>
    <%= button_to pin_fragment_observation_path(fragment, observation),
        method: :patch,
        class: "
          w-8
          h-8
          rounded-lg
          hover:bg-zinc-800
          transition
          flex
          items-center
          justify-center
          text-zinc-500
          hover:text-pink-400
        " do %>
      <%= lucide_icon "sparkles",
          class: "w-4 h-4" %>
    <% end %>
  <% end %>
  <button
  data-controller="copy"
  data-copy-text-value="<%= observation.content %>"
  data-action="click->copy#copy"
    class="
    w-8
    h-8
    rounded-lg
    hover:bg-zinc-800
    transition
    flex
    items-center
    justify-center
    text-zinc-500
    hover:text-white
    "
    >
    <span data-copy-target="copyIcon">
      <%= lucide_icon "copy",
        class: "w-4 h-4" %>
    </span>
    <span
    data-copy-target="checkIcon"
    class="hidden"
  >
      <%= lucide_icon "check",
        class: "w-4 h-4 text-green-400" %>
    </span>
  </button>
  <% if observation.role == "user" %>
    <button
      class="
        w-8
        h-8
        rounded-lg
        hover:bg-zinc-800
        transition
        flex
        items-center
        justify-center
        text-zinc-500
        hover:text-white
      "
    >
      <%= lucide_icon "square-pen",
          class: "w-4 h-4" %>
    </button>
  <% else %>
    <button
      class="
        w-8
        h-8
        rounded-lg
        hover:bg-zinc-800
        transition
        flex
        items-center
        justify-center
        text-zinc-500
        hover:text-white
      "
    >
      <%= lucide_icon "rotate-ccw",
          class: "w-4 h-4" %>
    </button>
  <% end %>
  <button
    class="
      w-8
      h-8
      rounded-lg
      hover:bg-zinc-800
      transition
      flex
      items-center
      justify-center
      text-zinc-500
      hover:text-white
    "
  >
    <%= lucide_icon "ellipsis",
        class: "w-4 h-4" %>
  </button>
</div>
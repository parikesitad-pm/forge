<div
  class="
    theme-surface
    border
    theme-border
    rounded-2xl
    px-6
    py-5
    mb-6
  "
>
  <div
    class="
      flex
      items-center
      justify-between

      mb-3
    "
  >
    <div
      class="
        flex
        items-center
        gap-2

        text-xs
        uppercase
        tracking-wider

        text-zinc-500
      "
    >
      <%= lucide_icon "sprout",
          class: "w-4 h-4" %>
      Seed
    </div>
    <div
      class="
        text-xs
        text-zinc-500
      "
    >
      <%= conversation_timestamp(fragment.created_at) %>
    </div>
  </div>
  <h1
    class="
      text-xs
      md:text-sm

      font-semibold

      leading-snug
      tracking-tight
    "
  >
    <%= fragment.content %>
  </h1>
</div>
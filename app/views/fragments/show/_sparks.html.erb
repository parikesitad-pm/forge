<%
  pinned = fragment.observations
                   .where(pinned: true)
                   .order(created_at: :desc)
%>
<% if pinned.any? %>
  <div
  data-controller="sparks"
  class="
    theme-surface
    border
    theme-border
    rounded-2xl
    mb-6
    overflow-hidden
  "
>
    <button
    data-action="click->sparks#toggle"
      class="
      w-full
      flex
      items-center
      justify-between
      px-6
      py-4
      hover:bg-zinc-800/30
      transition
      "
      >
      <div
      class="
        flex
        items-center
        gap-2
      "
    >
        <%= lucide_icon "sparkles",
          class: "w-4 h-4 text-amber-400" %>
        <span
        class="
          text-sm
          font-medium
        "
      >
          Sparks (<%= pinned.count %>)
        </span>
      </div>
      <%= lucide_icon "chevron-down",
        data: {
          sparks_target: "icon"
        },
        class: "
          w-4
          h-4
          transition-transform
          duration-200
        " %>
    </button>
    <div
    data-sparks-target="content"
    class="
      hidden

      border-t
      theme-border

      px-6
      py-5

      space-y-5
    "
  >
      <% pinned.each do |observation| %>
        <%= render "fragments/show/spark",
          observation: observation %>
      <% end %>
    </div>
  </div>
<% end %>
<div class="max-w-md mx-auto">
  <div class="theme-surface border theme-border rounded-2xl p-8">
    <h1 class="text-3xl font-bold mb-2">
      Create Account
    </h1>
    <p class="text-zinc-500 mb-8">
      Plant your first seed.
    </p>
    <%= form_with model: @user,
        url: register_path do |form| %>
      <!-- Username -->
      <div class="mb-5">
        <%= form.label :username,
            class: "block text-sm font-medium mb-2" %>
        <%= form.text_field :username,
            class: "
              w-full
              rounded-xl
              bg-transparent
              px-4
              py-3
              border
              transition

              #{@user.errors[:username].any? ?
                'border-red-500 focus:border-red-500' :
                'theme-border focus:border-pink-500'}
            " %>
        <% if @user.errors[:username].any? %>
          <div class="mt-2 flex items-center gap-2 text-sm text-red-400">
            <%= lucide_icon "circle-alert",
                class: "w-4 h-4 shrink-0" %>
            <span>
              <%= @user.errors[:username].first %>
            </span>
          </div>
        <% end %>
      </div>
      <!-- Email -->
      <div class="mb-5">
        <%= form.label :email,
            class: "block text-sm font-medium mb-2" %>
        <%= form.email_field :email,
            class: "
              w-full
              rounded-xl
              bg-transparent
              px-4
              py-3
              border
              transition

              #{@user.errors[:email].any? ?
                'border-red-500 focus:border-red-500' :
                'theme-border focus:border-pink-500'}
            " %>
        <% if @user.errors[:email].any? %>
          <div class="mt-2 flex items-center gap-2 text-sm text-red-400">
            <%= lucide_icon "circle-alert",
                class: "w-4 h-4 shrink-0" %>
            <span>
              <%= @user.errors[:email].first %>
            </span>
          </div>
        <% end %>
      </div>
      <!-- Password -->
      <div
  class="mb-5"
  data-controller="password"
>
        <%= form.label :password,
      class: "block text-sm font-medium mb-2" %>
        <%= form.password_field :password,
      data: {
        password_target: "input",
        action: "input->password#validate"
      },
      class: "
        w-full
        rounded-xl
        bg-transparent
        px-4
        py-3
        border
        theme-border
      "
  %>
        <div class="mt-4 space-y-2 text-sm">
          <div
      data-password-target="length"
      class="text-red-400"
    >
            <span class="status">○</span>
            At least 8 characters
          </div>
          <div
      data-password-target="uppercase"
      class="text-red-400"
    >
            <span class="status">○</span>
            One uppercase letter
          </div>
          <div
      data-password-target="lowercase"
      class="text-red-400"
    >
            <span class="status">○</span>
            One lowercase letter
          </div>
          <div
      data-password-target="number"
      class="text-red-400"
    >
            <span class="status">○</span>
            One number
          </div>
          <div
      data-password-target="symbol"
      class="text-red-400"
    >
            <span class="status">○</span>
            One symbol
          </div>
        </div>
      </div>
      <!-- Password Confirmation -->
      <div class="mb-8">
        <%= form.label :password_confirmation,
            class: "block text-sm font-medium mb-2" %>
        <%= form.password_field :password_confirmation,
            class: "
              w-full
              rounded-xl
              bg-transparent
              px-4
              py-3
              border
              theme-border
              transition
              focus:border-pink-500
            " %>
      </div>
      <button
        type="submit"
        class="
          w-full
          px-4
          py-3
          rounded-xl
          bg-pink-500
          hover:bg-pink-600
          text-white
          font-medium
          transition
        "
      >
        Create Account
      </button>
      <div class="mt-6 text-center text-sm text-zinc-500">
        Already have an account?
        <%= link_to "Sign In",
            login_path,
            class: "text-pink-400 hover:text-pink-300 ml-1" %>
      </div>
    <% end %>
  </div>
</div>
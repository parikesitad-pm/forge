<%= form_with model: @user,
    url: signup_path,
    data: {
      controller: "loading",
      action: "submit->loading#submit"
    } do |form| %>
  <!-- Username -->
  <div class="mb-5">
    <%= form.label :username, class: "block text-sm font-medium mb-2" %>
    <%= form.text_field :username, 
      class: "w-full rounded-xl bg-transparent px-4 py-3 border transition #{
        @user.errors[:username].any? ? 'border-red-500 focus:border-red-500' : 'theme-border focus:border-pink-500'} "
        %>
    <% if @user.errors[:username].any? %>
      <div class="mt-2 flex items-center gap-2 text-sm text-red-400">
        <%= lucide_icon "circle-alert", 
          class: "w-4 h-4 shrink-0" %>
        <span>
          <%= @user.errors[:username].first %>
        </span>
      </div>
    <% end %>
  </div>
  <!-- Email -->
  <div class="mb-5"> <%= form.label :email, class: "block text-sm font-medium mb-2" %>
    <%= form.email_field :email, 
    class: "w-full rounded-xl bg-transparent px-4 py-3 border transition #{@user.errors[:email].any? ? 'border-red-500 focus:border-red-500' : 'theme-border focus:border-pink-500'} " %>
    <% if @user.errors[:email].any? %>
      <div class="mt-2 flex items-center gap-2 text-sm text-red-400">
        <%= lucide_icon "circle-alert", 
          class: "w-4 h-4 shrink-0" %>
        <span>
          <%= @user.errors[:email].first %>
        </span>
      </div>
    <% end %>
  </div>
  <!-- Password -->
  <div data-controller="password" class="mb-8" >
    <!-- Password -->
    <div class="mb-5"> <%= form.label :password, 
      class: "block text-sm font-medium mb-2" %>
      <%= form.password_field :password, 
        data: { password_target: "input", action: "input->password#validate" }, 
        class: " w-full rounded-xl bg-transparent px-4 py-3 border theme-border " %>
      <div
        data-password-target="requirements"
        class="hidden mt-4 text-xs text-zinc-400 space-y-1"
      >
        <div class="flex flex-wrap gap-x-2 gap-y-1">
          <div data-password-target="length">
            <span class="status">
              ○
            </span>
            8+ chars
          </div>
          <div data-password-target="uppercase">
            <span class="status">
              ○
            </span>
            Uppercase
          </div>
          <div data-password-target="lowercase">
            <span class="status">
              ○
            </span> Lowercase
          </div>
          <div data-password-target="number">
            <span class="status">
              ○
            </span>
            Number
          </div>
          <div data-password-target="symbol">
            <span class="status">
              ○
            </span>
            Symbol
          </div>
        </div>
      </div>
      <% if @user.errors[:password].any? %>
        <div class="mt-3 flex items-center gap-2 text-xs text-red-400">
          <%= lucide_icon "circle-alert", class: "w-4 h-4 shrink-0" %>
          <span>
            <%= @user.errors[:password].first %>
          </span>
        </div>
      <% end %>
    </div>
    <!-- Password Confirmation -->
    <div>
      <%= form.label :password_confirmation, 
      class: "block text-sm font-medium mb-2" %>
      <%= form.password_field :password_confirmation, 
        data: { password_target: "confirmation", action: "input->password#validate" }, 
        class: " w-full rounded-xl bg-transparent px-4 py-3 border theme-border transition focus:border-pink-500 " %>
      <div
        data-password-target="match"
        class="hidden mt-3 flex items-center gap-2 text-sm text-zinc-500"
      >
        <span class="status">
          ○
        </span>
        <span data-password-target="matchText">
          Waiting for confirmation
        </span>
      </div>
      <% if @user.errors[:password_confirmation].any? %>
        <div class="mt-3 flex items-center gap-2 text-sm text-red-400">
          <%= lucide_icon "circle-alert", class: "w-4 h-4 shrink-0" %>
          <span>
            <%= @user.errors[:password_confirmation].first %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
  <button
    type="submit"
    data-loading-target="submit"
    class="
      w-full
      px-4
      py-3

      rounded-xl

      bg-pink-500
      hover:bg-pink-600

      disabled:bg-pink-400
      disabled:cursor-not-allowed

      text-white
      font-medium

      transition
    "
  >

    <span data-loading-target="content">
      Create Account
    </span>

    <span
      data-loading-target="skeleton"
      class="
        hidden
        flex
        items-center
        justify-center
        gap-2
      "
    >

      <svg
        class="w-4 h-4 animate-spin"
        viewBox="0 0 24 24"
        fill="none"
      >
        <circle
          cx="12"
          cy="12"
          r="10"
          stroke="white"
          stroke-width="3"
          opacity=".3"
        />

        <path
          d="M22 12A10 10 0 0012 2"
          stroke="white"
          stroke-width="3"
        />
      </svg>

      Registering Account...

    </span>

  </button>
  <div class="mt-6 text-center text-sm text-zinc-500">
    Already have an account?
    <%= link_to "Sign In", signin_path, class: "text-pink-400 hover:text-pink-300 ml-1" %>
  </div>
<% end %>
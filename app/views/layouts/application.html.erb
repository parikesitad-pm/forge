<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Forge" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body data-controller="theme" class="theme-body transition-all duration-300">
    <div data-controller="sidebar" class="min-h-screen">
      <nav class="h-16 theme-surface border-b theme-border flex items-center justify-between px-6">
        <div class="flex items-center gap-4">
          <button data-action="click->sidebar#toggle"
            data-sidebar-target="menuBtn"
            class="text-zinc-400 hover:text-pink-400 transition-colors duration-200"
            >
            <!-- Menu icon (default) -->
            <svg data-sidebar-target="iconMenu" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-all duration-300">
              <line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/>
            </svg>
            <!-- X icon (when open) -->
            <svg data-sidebar-target="iconClose" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden transition-all duration-300">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-pink-500"></div>
            <span class="font-bold text-lg">Forge</span>
          </div>
        </div>
        <div class="flex gap-2 items-center">
          <button
      data-action="click->theme#toggle"
            data-theme-target="themeBtn"
            class="px-3 py-2 rounded-lg border theme-border text-zinc-400 hover:text-pink-400 transition-colors duration-200"
            >
            <!-- Moon icon (default / light mode) -->
            <svg data-theme-target="iconMoon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <!-- Sun icon (dark mode active) -->
            <svg data-theme-target="iconSun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </button>
          <button class="px-4 py-2 rounded-lg bg-zinc-900 text-white hover:bg-zinc-700 transition-colors duration-200">
            Login
          </button>
        </div>
      </nav>
      <div class="flex">
        <aside
          data-sidebar-target="panel"
          class="
            w-64
            theme-surface
            border-r
            theme-border
            min-h-[calc(100vh-64px)]
            transition-all
            duration-300
          "
        >
          <div class="p-6">
            <nav class="space-y-2">
              <%= link_to root_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-zinc-200 dark:hover:bg-zinc-800 transition" do %>
                <span>
                  <%= lucide_icon "house"%>
                </span>
                <span data-sidebar-target="label">
                  Home
                </span>
              <% end %>
              <%= link_to fragments_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-zinc-200 dark:hover:bg-zinc-800 transition" do %>
                <span>
                  <%= lucide_icon "puzzle", class: "w-5 h-5" %>
                </span>
                <span data-sidebar-target="label">
                  Fragments
                </span>
              <% end %>
            </nav>
          </div>
        </aside>
        <main class="flex-1 p-8">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
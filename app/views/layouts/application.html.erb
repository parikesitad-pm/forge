<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Forge" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body data-controller="theme" class="theme-body transition-all duration-300">
    <div data-controller="sidebar" class="min-h-screen">
      <nav class="h-16 theme-surface border-b theme-border flex items-center justify-between px-6">
        <div class="flex items-center gap-4">
          <button
            data-action="click->sidebar#toggle"
            class="text-xl hover:text-pink-400 transition"
            >
            ☰
          </button>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-pink-500"></div>
            <span class="font-bold text-lg">
              Forge
            </span>
          </div>
        </div>
        <div class="flex gap-2">
          <button
            data-action="click->theme#toggle"
            class="px-3 py-2 rounded-lg border"
            >
            🌓
          </button>
          <button
            class="px-4 py-2 rounded-lg bg-zinc-900 text-white"
          >
            Login
          </button>
        </div>
      </nav>
      <div class="flex">
        <aside
          data-sidebar-target="panel"
          class="
            w-64
            theme-surface
            border-r
            theme-border
            min-h-[calc(100vh-64px)]
            transition-all
            duration-300
          "
        >
          <div class="p-6">
            <nav class="space-y-2">
              <%= link_to root_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-zinc-200 dark:hover:bg-zinc-800 transition" do %>
                <span>🏠</span>
                <span data-sidebar-target="label">
                  Home
                </span>
              <% end %>
              <%= link_to fragments_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-zinc-200 dark:hover:bg-zinc-800 transition" do %>
                <span>📄</span>
                <span data-sidebar-target="label">
                  Fragments
                </span>
              <% end %>
            </nav>
          </div>
        </aside>
        <main class="flex-1 p-8">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
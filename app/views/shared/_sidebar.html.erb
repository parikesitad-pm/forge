<aside
  data-sidebar-target="panel"
  class="
    w-64
    theme-surface
    border-r
    theme-border
    
    flex
    flex-col
    transition-all
    duration-300
  "
>
  <!-- Header -->
  <div
    class="
      h-16
      px-4
      border-b
      theme-border
      flex
      items-center
      shrink-0
      group
    "
  >
    <button
      data-action="click->sidebar#toggle"
      class="
      relative
      w-8
      h-8
      shrink-0
      "
      >
      <%= image_tag "icon.png",
        class: "
          absolute
          inset-0
          w-8
          h-8
          transition-opacity
          duration-200
          group-hover:opacity-0
        " %>
      <span
        class="
          absolute
          inset-0
          flex
          items-center
          justify-center
          opacity-0
          group-hover:opacity-100
          transition-opacity
          duration-200
        "
      >
        <%= lucide_icon "panel-left-close", class: "w-5 h-5" %>
      </span>
    </button>
    <span
      data-sidebar-target="label"
      class="ml-3 font-bold text-lg whitespace-nowrap"
    >
      Forge
    </span>
  </div>
  <!-- Navigation -->
  <div class="flex-1 p-4">
    <nav class="space-y-2">
      <%= link_to root_path,
          class: "
            flex
            items-center
            gap-3
            px-3
            py-3
            rounded-xl
            hover:bg-zinc-800
            transition
          " do %>
        <%= lucide_icon "house",
            class: "w-5 h-5 shrink-0" %>
        <span data-sidebar-target="label">
          Home
        </span>
      <% end %>
      <% if current_user %>
        <%= link_to fragments_path,
            class: "
              flex
              items-center
              gap-3
              px-3
              py-3
              rounded-xl
              hover:bg-zinc-800
              transition
            " do %>
          <%= lucide_icon "puzzle",
              class: "w-5 h-5 shrink-0" %>
          <span data-sidebar-target="label">
            Fragments
          </span>
        <% end %>
        <%= link_to settings_path,
          class: "
            flex
            items-center
            gap-3
            px-3
            py-3
            rounded-xl
            transition
            #{controller_name == "settings" ? "bg-zinc-800 text-white" : "hover:bg-zinc-800"}
          " do %>
          <%= lucide_icon "settings", class: "w-5 h-5 shrink-0" %>
          <span data-sidebar-target="label">
            Settings
          </span>
        <% end %>
      <% end %>
    </nav>
  </div>
  <!-- Profile -->
  <%= render "shared/profile_menu" if current_user %>
</aside>
<nav
  class="
    h-16
    theme-surface
    border-b
    theme-border
    flex
    items-center
    justify-between
    px-6
  "
>
  <div class="flex items-center gap-4">
    <%= render "shared/breadcrumb" %>
  </div>
  <div class="flex items-center gap-3">
    <button
      class="
        px-4
        py-2
        rounded-lg
        border
        theme-border
        hover:bg-zinc-800
      "
    >
      Share
    </button>
    <button
      data-action="click->theme#toggle"
      class="
      px-3
      py-2
      rounded-lg
      border
      theme-border
      hover:bg-zinc-800
      transition
      "
      >
      <span data-theme-target="iconMoon">
        <%= lucide_icon "moon", class: "w-4 h-4" %>
      </span>
      <span
          data-theme-target="iconSun"
          class="hidden"
        >
        <%= lucide_icon "sun", class: "w-4 h-4" %>
      </span>
    </button>
  </div>
</nav>
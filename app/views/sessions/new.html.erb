<div class="max-w-md mx-auto">
  <div class="theme-surface border theme-border rounded-2xl p-8">
    <h1 class="text-3xl font-bold mb-2">
      Welcome Back
    </h1>
    <p class="text-zinc-500 mb-8">
      Continue thinking.
    </p>
    <%= form_with url: login_path do %>
      <div class="mb-4">
        <label class="block text-sm mb-2">
          Username or Email
        </label>
        <%= text_field_tag :identifier,
            nil,
            class: "w-full rounded-xl border theme-border bg-transparent p-3" %>
      </div>
      <div class="mb-6">
        <label class="block text-sm mb-2">
          Password
        </label>
        <%= password_field_tag :password,
            nil,
            class: "w-full rounded-xl border theme-border bg-transparent p-3" %>
      </div>
      <button
        type="submit"
        class="w-full px-4 py-3 rounded-xl bg-pink-500 hover:bg-pink-600 text-white font-medium transition"
      >
        Login
      </button>
      <div class="mt-6 text-center text-sm text-zinc-500">
        Don't have an account?
        <%= link_to "Sign Up",
            register_path,
            class: "text-pink-400 hover:text-pink-300 ml-1" %>
      </div>
    <% end %>
  </div>
</div>
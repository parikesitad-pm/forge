<%= form_with url: signin_path do %>
  <div class="mb-4">
    <label class="block text-sm mb-2">
      Username or Email
    </label>
    <%= text_field_tag :identifier,
        nil,
        class:"
          w-full
          rounded-xl
          border
          theme-border
          bg-transparent
          p-3
        " %>
  </div>
  <div class="mb-6">
    <label class="block text-sm mb-2">
      Password
    </label>
    <%= password_field_tag :password,
        nil,
        class:"
          w-full
          rounded-xl
          border
          theme-border
          bg-transparent
          p-3
        " %>
  </div>
  <button
    type="submit"
    class="
      w-full
      px-4
      py-3
      rounded-xl
      bg-pink-500
      hover:bg-pink-600
      text-white
      font-medium
      transition
    "
  >
    Login
  </button>
  <div class="mt-6 text-center text-sm text-zinc-500">
    Don't have an account?
    <%= link_to "Sign Up",
        signup_path,
        class:"
          ml-1
          text-pink-400
          hover:text-pink-300
        " %>
  </div>
<% end %>